PORT=3001
NODE_ENV=development
YELP_API_KEY=your_yelp_api_key_here
ADMIN_EMAILS=your@email.com
ADMIN_SECRET=change-this-in-production
# Turso Cloud DB (production) — get from turso.tech
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-auth-token
#
# Leave blank to use local SQLite (development)
JWT_SECRET=generate_with_node_crypto
WA_CLIENT_ID=optional_wild_apricot_client_id
WA_CLIENT_SECRET=optional_wild_apricot_secret
WA_ACCOUNT_URL=https://yourorg.wildapricot.org
CORS_ORIGINS=https://your-app.up.railway.app
